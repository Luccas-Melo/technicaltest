{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "parte-1 (static)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8001", "--directory", "parte-1"],
      "port": 8001
    },
    {
      "name": "parte-2 (static)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8002", "--directory", "parte-2"],
      "port": 8002
    },
    {
      "name": "parte-1 tailwind watch",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["tailwindcss", "-i", "parte-1/src/input.css", "-o", "parte-1/css/tailwind.css", "--watch"],
      "port": 0
    }
  ]
}
